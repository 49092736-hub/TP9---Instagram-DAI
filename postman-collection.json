    {
      "name": "PUBLICACIONES",
      "item": [
        {
          "name": "Crear publicación (token requerido)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"url_imagen\": \"https://cdn2.thecatapi.com/images/MTY3ODIyMQ.jpg\",\n  \"descripcion\": \"Mi gato disfrutando del sol en la terraza\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/publicaciones",
              "host": ["{{base_url}}"],
              "path": ["publicaciones"]
            }
          }
        },
        {
          "name": "Obtener todas las publicaciones (feed)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/publicaciones?page=1&limit=20",
              "host": ["{{base_url}}"],
              "path": ["publicaciones"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "20"
                }
              ]
            }
          }
        },
        {
          "name": "Mis publicaciones (token requerido)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/mis-publicaciones",
              "host": ["{{base_url}}"],
              "path": ["mis-publicaciones"]
            }
          }
        },
        {
          "name": "Publicaciones de usuario",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/publicaciones/1",
              "host": ["{{base_url}}"],
              "path": ["publicaciones", "1"]
            }
          }
        },
        {
          "name": "Like en publicación (token requerido)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/publicaciones/1/like",
              "host": ["{{base_url}}"],
              "path": ["publicaciones", "1", "like"]
            }
          }
        },
        {
          "name": "Eliminar publicación (token requerido)",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/publicaciones/1",
              "host": ["{{base_url}}"],
              "path": ["publicaciones", "1"]
            }
          }
        }
      ]
