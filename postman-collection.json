    {
      "name": "PERFIL",
      "item": [
        {
          "name": "Ver mi perfil (token requerido)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/perfil",
              "host": ["{{base_url}}"],
              "path": ["perfil"]
            }
          }
        },
        {
          "name": "Ver perfil de otro usuario",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/perfil/mariag",
              "host": ["{{base_url}}"],
              "path": ["perfil", "mariag"]
            }
          }
        },
        {
          "name": "Actualizar perfil (token requerido)",
          "request": {
            "method": "PUT",
            "header": [
              {
